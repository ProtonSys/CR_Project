function configs = createNNConfigGrid()
% CREATENNCONFIGGRID Gera o conjunto de configurações das redes neuronais.
%
% Esta função cria automaticamente diferentes configurações de redes
% neuronais feedforward para serem utilizadas nas experiências.
%
% Cada configuração inclui:
%   - topologia da rede
%   - algoritmo de treino
%   - função de ativação da saída
%   - divisão treino/validação/teste
%   - número de épocas
%   - learning rate
%
% As configurações geradas são utilizadas posteriormente no script
% main_nn_experiments.m.
%
% Saídas:
%   configs - vetor de estruturas contendo as configurações
%
% Autor: Celso Jordão
% nº 2003008910
% Unidade Curricular: Conhecimento e Raciocínio
% Trabalho Prático 2025/2026

    % ---------------------------------------------------------------------
    % Definição das topologias das redes
    % ---------------------------------------------------------------------
    % Cada elemento representa:
    %   - número de neurónios por camada escondida
    %
    % Exemplos:
    %   [10]     -> 1 camada escondida com 10 neurónios
    %   [20 10]  -> 2 camadas escondidas
    hiddenList = {
        [10]
        [20 10]
        [30]
        [20 10]
        [30 15]
    };

    % ---------------------------------------------------------------------
    % Algoritmos de treino
    % ---------------------------------------------------------------------
    % trainbr:
    %   Bayesian Regularization Backpropagation
    %
    % Este algoritmo tende a apresentar boa generalização.
    trainFcns = {
        'trainscg'
        'trainnlm'
        };

    % ---------------------------------------------------------------------
    % Funções de ativação da camada de saída
    % ---------------------------------------------------------------------
    % logsig:
    %   função logística sigmoidal
    outputFcns = {
        'logsig'
        'tansig'
        };

    % ---------------------------------------------------------------------
    % Divisão treino / validação / teste
    % ---------------------------------------------------------------------
    % Formato:
    %   [train validation test]
    %
    % Neste caso:
    %   70% treino
    %   15% validação
    %   15% teste
    divisions = [
        0.70 0.15 0.15
        '.8
    ];

    % ---------------------------------------------------------------------
    % Número máximo de épocas
    % ---------------------------------------------------------------------
    % Cada época corresponde a uma passagem completa pelos dados de treino.
    epochsList = [100];

    % ---------------------------------------------------------------------
    % Learning rates
    % ---------------------------------------------------------------------
    % Controla a velocidade de aprendizagem da rede.
    lrList = [0.01];

    % ---------------------------------------------------------------------
    % Inicialização da estrutura de configurações
    % ---------------------------------------------------------------------
    k = 1;

    configs = struct([]);

    % ---------------------------------------------------------------------
    % Geração automática de todas as combinações possíveis
    % ---------------------------------------------------------------------
    for h = 1:numel(hiddenList)

        for t = 1:numel(trainFcns)

            for o = 1:numel(outputFcns)

                for d = 1:size(divisions,1)

                    for e = 1:numel(epochsList)

                        for lr = 1:numel(lrList)

                            % -------------------------------------------------
                            % Topologia da rede
                            % -------------------------------------------------
                            configs(k).hiddenLayers = hiddenList{h};

                            % -------------------------------------------------
                            % Algoritmo de treino
                            % -------------------------------------------------
                            configs(k).trainFcn = trainFcns{t};

                            % -------------------------------------------------
                            % Função de ativação da saída
                            % -------------------------------------------------
                            configs(k).outputFcn = outputFcns{o};

                            % -------------------------------------------------
                            % Percentagens de divisão dos dados
                            % -------------------------------------------------
                            configs(k).trainRatio = divisions(d,1);

                            configs(k).valRatio = divisions(d,2);

                            configs(k).testRatio = divisions(d,3);

                            % -------------------------------------------------
                            % Número de épocas
                            % -------------------------------------------------
                            configs(k).epochs = epochsList(e);

                            % -------------------------------------------------
                            % Learning rate
                            % -------------------------------------------------
                            configs(k).lr = lrList(lr);

                            % Passa para a próxima configuração
                            k = k + 1;

                        end
                    end
                end
            end
        end
    end
end